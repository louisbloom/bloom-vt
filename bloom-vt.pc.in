prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: bloom-vt
Description: Standalone virtual terminal engine (UAX-aware grapheme clustering, scrollback, reflow)
URL: https://github.com/thomas-christensen/bloom-vt
Version: @PACKAGE_VERSION@
Cflags: -I${includedir}
Libs: -L${libdir} -lbloom-vt
